# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# SQLite database location (relative to the server/ folder).
DATABASE_URL="file:./dev.db"

# Owner-only write access. Generate a long random secret, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Sent by the owner as `Authorization: Bearer <token>` on write requests.
ADMIN_TOKEN="replace-with-a-long-random-secret"
